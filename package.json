{
  "name": "clickingff7",
  "version": "1.4.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "deploy": "ng build && firebase deploy",
    "lint": "biome check",
    "lint:staged": "biome check --staged",
    "lint:ci": "biome ci",
    "madge:ci": "madge --circular --ts-config ./tsconfig.json --extensions ts,tsx src",
    "check": "pnpm run lint:ci && pnpm run test:ci",
    "i18n:download": "crowdin download --identity .crowdin.yml"
  },
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "dependencies": {
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "@lucide/angular": "^1.18.0",
    "intro.js": "^7.2.0",
    "rxjs": "~7.8.2",
    "subsink": "^1.0.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@biomejs/biome": "2.4.10",
    "@tailwindcss/postcss": "^4.1.17",
    "daisyui": "5.5.23",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.1.14",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
}
